# See https://wiki.hyprland.org/Configuring/Dwindle-Layout/

dwindle {
    pseudotile = true
    preserve_split = true
}

# See https://wiki.hyprland.org/Configuring/Master-Layout/

master {
    new_is_master = true
    orientation = center
    always_center_master=true
    smart_resizing = true
}



# window control
bind = $mainMode, R, slidr:cyclesize
bind = $mainMode, T, slidr:alignwindow, c
bind = $mainMode, J, slidr:alignwindow, l
bind = $mainMode, N, slidr:alignwindow, r
bind = $mainMode SHIFT, F, fullscreen,0
bind = $mainMode, F, fullscreen,1
bind = $mainMode, I, slidr:admitwindow
bind = $mainMode, o, slidr:expelwindow
